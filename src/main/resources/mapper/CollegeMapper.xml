<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ujs.trainingprogram.tp.dao.mapper.CollegeMapper">

    <!-- 分页查询学院 -->
    <select id="pageCollegeResult" parameterType="com.ujs.trainingprogram.tp.dto.req.college.CollegePageReqDTO"
            resultType="com.ujs.trainingprogram.tp.dto.CollegePageMajorDTO">
        SELECT
            c.id,
            c.college_code,
            c.college_name,
            c.del_flag AS delFlag,
            m.major_code,
            m.major_name,
            m.course_num,
            CASE m.category
            WHEN 0 THEN '工学'
            WHEN 1 THEN '理学'
            WHEN 2 THEN '文科'
            ELSE '未知'
            END AS category
        FROM college c
        LEFT JOIN major m ON c.id = m.college_id
        WHERE 1=1
            <if test="requestParam.collegeIds != null and requestParam.collegeIds.size() >= 0">
                AND c.id IN
                <foreach collection="requestParam.collegeIds" item="collegeId" open="(" separator="," close=")">
                    #{collegeId}
                </foreach>
            </if>
            <if test="requestParam.collegeNames != null and requestParam.collegeNames.size() >= 0">
                AND (
                <foreach collection="requestParam.collegeNames" item="collegeName" open="" separator=" OR " close="">
                    c.college_name LIKE CONCAT('%', #{collegeName}, '%')
                </foreach>
                )
            </if>
        ORDER BY c.create_time DESC
    </select>


</mapper>