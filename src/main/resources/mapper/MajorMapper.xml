<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ujs.trainingprogram.tp.dao.mapper.MajorMapper">

    <!-- 分页查询专业信息 -->
    <select id="pageMajorResults" parameterType="com.ujs.trainingprogram.tp.dto.req.major.MajorPageReqDTO"
            resultType="com.ujs.trainingprogram.tp.dto.resp.major.MajorPageRespDTO">
        SELECT
            m.id,
            m.major_code,
            m.college_id,
            m.major_name,
            c.college_name,
            m.course_num,
            m.del_flag AS delFlag,
            CASE m.category
                WHEN 0 THEN '工学'
                WHEN 1 THEN '理学'
                WHEN 2 THEN '文科'
                ELSE '未知'
            END AS category,
            m.create_time,
            m.update_time
        FROM major m
        LEFT JOIN college c ON m.college_id = c.id
        <where>
            1=1
            <if test="requestParam.majorNames != null and requestParam.majorNames.size() >= 0">
                AND (
                <foreach collection="requestParam.majorNames" item="majorName" open="" separator=" OR " close="">
                    m.major_name LIKE CONCAT('%', #{majorName}, '%')
                </foreach>
                )
            </if>
            <if test="requestParam.majorIds != null and requestParam.majorIds.size() >= 0">
                AND m.id IN
                <foreach collection="requestParam.majorIds" item="majorId" open="(" separator="," close=")">
                    #{majorId}
                </foreach>
            </if>
            <if test="requestParam.collegeNames != null and requestParam.collegeNames.size() >= 0">
                AND (
                <foreach collection="requestParam.collegeNames" item="collegeName" open="" separator=" OR " close="">
                    c.college_name LIKE CONCAT('%', #{collegeName}, '%')
                </foreach>
                )
            </if>
            <if test="requestParam.categoryId != null">
                AND m.category_id = #{requestParam.categoryId}
            </if>
        </where>
        ORDER BY m.create_time DESC
    </select>

    <update id="incrementCourseNum">
        UPDATE major
        SET course_num = course_num + #{incrementNum}
        WHERE id = #{majorId}
    </update>

    <update id="decrementCourseNum">
        UPDATE major
        SET course_num = course_num - #{decrementNum}
        WHERE id = #{majorId}
    </update>

</mapper>