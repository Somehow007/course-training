<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ujs.trainingprogram.tp.dao.mapper.CourseExclusivityMapper">

    <!-- 根据培养计划 Id 查询课程及其分组情况 -->
    <select id="selectCourseToExclusivity"
            resultType="com.ujs.trainingprogram.tp.dto.resp.courseexclusivity.CourseToExclusivityRespDTO">
        SELECT
            ce.group_code AS groupCode,
            ced.course_id AS courseId,
            c.course_name AS courseName
        FROM
            course_exclusivity ce
        LEFT JOIN course_exclusivity_detail ced ON ce.id = ced.exclusivity_id
        LEFT JOIN course c ON ced.course_id = c.id
        WHERE
            ce.del_flag = 0 AND ce.training_program_id = #{tpId}

    </select>



</mapper>